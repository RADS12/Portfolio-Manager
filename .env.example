# ══════════════════════════════════════════════════════════════════════════════
# PortfolioIQ — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# FIRST-TIME SETUP (3 steps):
#
#   1. Copy this file:
#      Copy-Item .env.example .env
#
#   2. Generate a SECRET_KEY and paste it below:
#      python -c "import secrets; print(secrets.token_hex(32))"
#
#   3. Start the stack:
#      cd infrastructure
#      docker compose up --build
#
# Everything else below works out of the box for local development.
# Only SECRET_KEY needs to be changed before first run.
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: change this before first run ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_ME_run_python_secrets_token_hex_32

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (works as-is with Docker Compose) ────────────────────────────────
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://portfolioiq:devpassword@localhost:5432/portfolioiq
DATABASE_URL_SYNC=postgresql://portfolioiq:devpassword@localhost:5432/portfolioiq

# ── Redis (works as-is with Docker Compose) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── File storage / MinIO (works as-is with Docker Compose) ───────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=portfolioiq-uploads
S3_REGION=us-east-1

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ── Market data cache TTLs ────────────────────────────────────────────────────
PRICE_CACHE_MINUTES=15
HOLDINGS_CACHE_HOURS=24

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=60/minute
RATE_LIMIT_REFRESH=1/5minutes

# ── OAuth — leave blank to disable Google login ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Stripe — leave blank to disable billing ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
